<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="@dimen/pa_row_height"
    android:orientation="horizontal"
    android:gravity="center_vertical"
    android:background="@drawable/row_bg"
    android:paddingHorizontal="16dp">

    <ImageView
        android:id="@+id/thumb"
        android:layout_width="@dimen/pa_row_thumb"
        android:layout_height="@dimen/pa_row_thumb"
        android:scaleType="fitCenter"
        android:src="@drawable/matte_folder_96"
        android:contentDescription="@null" />

    <LinearLayout
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:layout_weight="1"
        android:layout_marginStart="14dp"
        android:orientation="vertical">

        <TextView
            android:id="@+id/title"
            style="@style/Tb.ListTitle"
            android:layout_width="match_parent"
            android:layout_height="wrap_content" />

        <TextView
            android:id="@+id/subtitle"
            style="@style/Tb.ListSubtitle"
            android:layout_width="match_parent"
            android:layout_height="wrap_content" />
    </LinearLayout>
</LinearLayout>
