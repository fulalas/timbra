<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="@dimen/pa_row_height"
    android:orientation="horizontal"
    android:gravity="center_vertical"
    android:background="@drawable/row_bg"
    android:paddingStart="16dp"
    android:paddingEnd="4dp">

    <ImageView
        android:id="@+id/thumb"
        android:layout_width="@dimen/pa_row_thumb"
        android:layout_height="@dimen/pa_row_thumb"
        android:scaleType="fitCenter"
        android:src="@drawable/matte_album_96"
        android:contentDescription="@null" />

    <LinearLayout
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:layout_weight="1"
        android:layout_marginStart="14dp"
        android:orientation="vertical">

        <TextView
            android:id="@+id/title"
            style="@style/Tb.ListTitle"
            android:layout_width="match_parent"
            android:layout_height="wrap_content" />

        <TextView
            android:id="@+id/subtitle"
            style="@style/Tb.ListSubtitle"
            android:layout_width="match_parent"
            android:layout_height="wrap_content" />
    </LinearLayout>

    <ImageView
        android:id="@+id/drag_handle"
        android:layout_width="48dp"
        android:layout_height="48dp"
        android:padding="12dp"
        android:scaleType="fitCenter"
        android:src="@drawable/ic_drag_handle"
        android:contentDescription="@string/cd_reorder" />
</LinearLayout>
